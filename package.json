    "jsonwebtoken": "^9.0.3",
    "lowlight": "^3.3.0",
    "next": "^16.0.10",
    "nodemailer": "^7.0.11",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "turndown": "^7.2.2",
    "uuid": "^13.0.0"
